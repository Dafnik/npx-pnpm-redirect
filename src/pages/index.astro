---
import "../styles/global.css";
import {CodeBlock} from "@/components/CodeBlock.tsx";
import {ShellSelector} from "@/components/ShellSelector.tsx";
import {ShellPath} from "@/components/ShellPath.tsx";
import {ShellCodeBlock} from "@/components/ShellCodeBlock.tsx";
import {ShellSourceBlock} from "@/components/ShellSourceBlock.tsx";
import {ShellAIPrompt} from "@/components/ShellAIPrompt.tsx";
import {ShellLabel} from "@/components/ShellLabel.tsx";
import {ShellRcFile} from "@/components/ShellRcFile.tsx";

const title = "Stop replacing npx with pnpm dlx by hand.";
const description = "Paste the command exactly as the README wrote it. Your shell can intercept npx and run pnpm dlx instead.";
const verifyCommand = 'npx cowsay "I use pnpm now"';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="viewport" content="width=device-width" />

    <link rel="icon" href={`${base}/icon-light-32x32.png`} media="(prefers-color-scheme: light)" />
    <link rel="icon" href={`${base}/icon-dark-32x32.png`} media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${base}/icon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/apple-icon.png`} />
    <title>{title}</title>
  </head>
  <body>
    <main class="flex min-h-screen items-center justify-center bg-background px-6 py-16 text-foreground">
      <article class="w-full max-w-xl space-y-10">
        <header class="hero-header">
          <div class="space-y-4">
            <h1 class="text-balance text-5xl font-black tracking-tight">
              Stop replacing
              <br/>
              <span class="inline-flex sm:block flex-col">
              <span class="hero-mark typewriter" aria-label="npx">
                <span class="typewriter-text" aria-hidden="true"></span>
              </span>
              by hand.
              </span>
            </h1>
            <p class="text-pretty text-lg font-semibold text-muted-foreground">
              Paste the command exactly as the README wrote it. Your shell can
              intercept <code class="rounded bg-muted px-1">npx</code> and run
              <strong>pnpm dlx</strong> instead.
            </p>
          </div>
        </header>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Step 1 - Open your shell config
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            Since you're using <ShellLabel client:load />, the file you're
            looking for is:
          </p>
          <ShellPath client:load />
        </section>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Step 2 - Paste this function
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            Add the following to the bottom of <ShellRcFile client:load />. Yes,
            the whole thing.
          </p>
          <ShellCodeBlock client:load />
        </section>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Step 3 - Reload your shell
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            The file doesn't reload itself. Run this:
          </p>
          <ShellSourceBlock client:load />
          <p class="text-sm font-bold text-muted-foreground">
            Or just open a new terminal tab like a normal person.
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-black uppercase">Step 4 - Verify it works</h2>
          <CodeBlock code={verifyCommand} client:load />
          <p class="font-bold text-muted-foreground">
            If a cow says it, it's true.
          </p>
        </section>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Too lazy? Give this to your AI
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            Can't be bothered to do four whole steps? Fine. This prompt is
            already tailored to <ShellLabel client:load /> - just copy and paste
            it.
          </p>
          <ShellAIPrompt client:load />
        </section>

        <div class="flex flex-col sm:flex-row gap-6 justify-between border-t pt-6 text-xs font-bold text-muted-foreground">
          <div class="flex flex-col">
        <span>
          That's it. Four steps. You've earned a coffee.
        </span>
            <span>
                Like the site? Check it out on <a class="underline" href="https://github.com/Dafnik/npx-pnpm-redirect" rel="noopener" target="_blank">GitHub</a>.
        </span>
          </div>
          <span>
            by <a class="underline" href="https://dafnik.me" rel="noopener" target="_blank">Dafnik</a>
          </span>
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  .hero-header {
    --hero-glow: rgb(239 29 40 / 0.18);
    --hero-shade: rgb(0 0 0 / 0.08);
    --hero-typewriter: darkviolet;

    position: relative;
    display: grid;
    gap: 1.5rem;
    isolation: isolate;
  }

  .hero-header::before {
    position: absolute;
    inset: -1.25rem -1.25rem auto;
    z-index: -1;
    height: 13rem;
    background:
      radial-gradient(circle at 18% 28%, var(--hero-glow), transparent 34%),
      linear-gradient(135deg, var(--hero-shade), transparent 55%);
    border-radius: 1.75rem;
    content: "";
    transform: rotate(-1.5deg);
  }

  .typewriter {
    color: var(--hero-typewriter);
    min-width: 8ch;
    white-space: nowrap;
  }

  .typewriter-text::before {
    content: "npx";
    animation: typewriter-text 5s steps(1, end) infinite;
  }

  .typewriter-text::after {
    display: inline-block;
    width: 0.08em;
    height: 0.86em;
    margin-left: 0.06em;
    background: currentColor;
    content: "";
    transform: translateY(0.1em);
    animation: typewriter-cursor 900ms steps(1, end) infinite;
  }

  @keyframes typewriter-text {
    0%,
    12% {
      content: "npx";
    }

    15% {
      content: "np";
    }

    18% {
      content: "n";
    }

    21% {
      content: "";
    }

    25% {
      content: "p";
    }

    28% {
      content: "pn";
    }

    31% {
      content: "pnp";
    }

    34% {
      content: "pnpm";
    }

    37% {
      content: "pnpm ";
    }

    40% {
      content: "pnpm d";
    }

    43% {
      content: "pnpm dl";
    }

    46%,
    60% {
      content: "pnpm dlx";
    }

    64% {
      content: "pnpm dl";
    }

    68% {
      content: "pnpm d";
    }

    72% {
      content: "pnpm ";
    }

    75% {
      content: "pnpm";
    }

    78% {
      content: "pnp";
    }

    81% {
      content: "pn";
    }

    84% {
      content: "p";
    }

    87% {
      content: "";
    }

    91% {
      content: "n";
    }

    94% {
      content: "np";
    }

    97%,
    100% {
      content: "npx";
    }
  }

  @keyframes typewriter-cursor {
    0%,
    48% {
      opacity: 1;
    }

    49%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-color-scheme: dark) {
    .hero-header {
      --hero-glow: rgb(239 29 40 / 0.24);
      --hero-shade: rgb(255 255 255 / 0.08);
      --hero-typewriter: #c084fc;
    }
  }

</style>
