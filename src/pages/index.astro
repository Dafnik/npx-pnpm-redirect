---
import "../styles/global.css";
import {CodeBlock} from "@/components/CodeBlock.tsx";
import {ShellSelector} from "@/components/ShellSelector.tsx";
import {ShellPath} from "@/components/ShellPath.tsx";
import {ShellCodeBlock} from "@/components/ShellCodeBlock.tsx";
import {ShellSourceBlock} from "@/components/ShellSourceBlock.tsx";
import {ShellAIPrompt} from "@/components/ShellAIPrompt.tsx";
import {ShellLabel} from "@/components/ShellLabel.tsx";
import {ShellRcFile} from "@/components/ShellRcFile.tsx";

const title = "Stop Using npx";
const description = "How to redirect npx to pnpm dlx in your shell";
const verifyCommand = 'npx cowsay "I use pnpm now"';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />

    <link rel="icon" href={`${base}/icon-light-32x32.png`} media="(prefers-color-scheme: light)" />
    <link rel="icon" href={`${base}/icon-dark-32x32.png`} media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${base}/icon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/apple-icon.png`} />
    <title>{title}</title>
  </head>
  <body>
    <main class="flex min-h-screen items-center justify-center bg-background px-6 py-16 text-foreground">
      <article class="w-full max-w-xl space-y-10">
        <header class="hero-header">
          <div class="space-y-4">
            <h1 class="text-balance text-5xl font-black tracking-tight">
              Stop replacing
              <span class="hero-mark">npx</span>
              by hand.
            </h1>
            <p class="text-pretty text-lg font-semibold text-muted-foreground">
              Paste the command exactly as the README wrote it. Your shell can
              intercept <code class="rounded bg-muted px-1">npx</code> and run
              <strong>pnpm dlx</strong> instead.
            </p>
          </div>
        </header>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Step 1 - Open your shell config
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            Since you're using <ShellLabel client:load />, the file you're
            looking for is:
          </p>
          <ShellPath client:load />
        </section>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Step 2 - Paste this function
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            Add the following to the bottom of <ShellRcFile client:load />. Yes,
            the whole thing.
          </p>
          <ShellCodeBlock client:load />
        </section>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Step 3 - Reload your shell
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            The file doesn't reload itself. Run this:
          </p>
          <ShellSourceBlock client:load />
          <p class="text-sm font-bold text-muted-foreground">
            Or just open a new terminal tab like a normal person.
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-black uppercase">Step 4 - Verify it works</h2>
          <CodeBlock code={verifyCommand} client:load />
          <p class="font-bold text-muted-foreground">
            If a cow says it, it's true.
          </p>
        </section>

        <section class="space-y-3">
          <div class="flex items-center gap-3">
            <h2 class="flex-1 text-xl font-black uppercase">
              Too lazy? Give this to your AI
            </h2>
            <ShellSelector client:load />
          </div>
          <p class="font-bold text-muted-foreground">
            Can't be bothered to do four whole steps? Fine. This prompt is
            already tailored to <ShellLabel client:load /> - just copy and paste
            it.
          </p>
          <ShellAIPrompt client:load />
        </section>

        <p class="border-t pt-6 text-xs font-bold text-muted-foreground">
          That's it. Four steps. You've earned a coffee.
        </p>
      </article>
    </main>
  </body>
</html>

<style>
  .hero-header {
    position: relative;
    display: grid;
    gap: 1.5rem;
    isolation: isolate;
  }

  .hero-header::before {
    position: absolute;
    inset: -1.25rem -1.25rem auto;
    z-index: -1;
    height: 13rem;
    background:
      radial-gradient(circle at 18% 28%, rgb(239 29 40 / 0.18), transparent 34%),
      linear-gradient(135deg, rgb(0 0 0 / 0.08), transparent 55%);
    border-radius: 1.75rem;
    content: "";
    transform: rotate(-1.5deg);
  }

  .hero-mark {
    position: relative;
    display: inline-block;
    padding-inline: 0.08em;
    font-family: var(--font-mono);
  }

  .hero-mark::after {
    position: absolute;
    right: 0.02em;
    bottom: 0.16em;
    left: 0.02em;
    height: 0.16em;
    background: #ef1d28;
    content: "";
    transform: rotate(-4deg);
    transform-origin: left center;
  }
</style>
